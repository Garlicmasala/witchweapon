"""
Daily Missions System for Witch's Weapon.
Handles daily mission generation, progress tracking, and rewards.
"""

import json
import os
from dataclasses import dataclass, asdict
from datetime import datetime, time
from typing import Dict, List, Optional, Any
from enum import Enum

class MissionCategory(Enum):
    PVE_COMBAT = "pve_combat"
    PVP_PARTICIPATION = "pvp_participation"
    WEAPON_USAGE = "weapon_usage"
    VISUAL_NOVEL = "visual_novel"
    SOCIAL_FASHION = "social_fashion"

@dataclass
class MissionReward:
    currency: Optional[str] = None
    amount: int = 0
    item: Optional[str] = None
    item_amount: int = 0

@dataclass
class DailyMission:
    id: str
    category: MissionCategory
    title: str
    description: str
    target: int
    reward: MissionReward
    optional: bool = False
    progress: int = 0
    completed: bool = False
    claimed: bool = False

class DailyMissionManager:
    def __init__(self, currency_manager, save_file="daily_missions.json"):
        self.currency_manager = currency_manager
        self.save_file = save_file
        self.missions: List[DailyMission] = []
        self.last_reset_date = None
        self.completion_bonus_claimed = False
        self.mission_pool = self._load_mission_pool()
        self._check_daily_reset()

    def _load_mission_pool(self) -> List[Dict[str, Any]]:
        """Load mission pool from JSON file or use defaults."""
        pool_file = "src/daily_mission_pool.json"
        if os.path.exists(pool_file):
            with open(pool_file, 'r') as f:
                return json.load(f)
        else:
            return self._get_default_mission_pool()

