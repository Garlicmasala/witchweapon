            }
        ]

    def _check_daily_reset(self):
        """Check if it's a new day and reset missions if needed."""
        today = datetime.now().date()
        if self.last_reset_date != today:
            self._reset_daily_missions()
            self.last_reset_date = today
            self.completion_bonus_claimed = False

    def _reset_daily_missions(self):
        """Generate new daily missions."""
        import random
        random.seed(datetime.now().date().toordinal())  # Consistent per day

        # Select 3-5 missions with category balance
        selected = []
        categories = [MissionCategory.PVE_COMBAT, MissionCategory.WEAPON_USAGE, MissionCategory.VISUAL_NOVEL]
        optional_categories = [MissionCategory.PVP_PARTICIPATION, MissionCategory.SOCIAL_FASHION]

        # Always include at least 1 PvE
        pve_pool = [m for m in self.mission_pool if m["category"] == "pve_combat"]
        selected.append(random.choice(pve_pool))

        # Add more from main categories
        main_pool = [m for m in self.mission_pool if m["category"] in ["weapon_usage", "visual_novel"]]
        selected.extend(random.sample(main_pool, min(2, len(main_pool))))

        # Add optional PvP or fashion
        optional_pool = [m for m in self.mission_pool if m["category"] in ["pvp_participation", "social_fashion"]]
        if optional_pool:
            selected.append(random.choice(optional_pool))

        # Convert to DailyMission objects
        self.missions = []
        for m_data in selected[:5]:  # Max 5
            reward = MissionReward(**m_data["reward"])
            mission = DailyMission(
                id=m_data["id"],
                category=MissionCategory(m_data["category"]),
                title=m_data["title"],
                description=m_data["description"],
                target=m_data["target"],
                reward=reward,
                optional=m_data.get("optional", False)
            )
            self.missions.append(mission)

    def get_daily_missions(self) -> List[DailyMission]:
        """Get current daily missions."""
        self._check_daily_reset()
        return self.missions

    def update_progress(self, mission_id: str, amount: int = 1):
        """Update progress for a mission."""
        for mission in self.missions:
            if mission.id == mission_id and not mission.completed:
                mission.progress = min(mission.progress + amount, mission.target)
                if mission.progress >= mission.target:
                    mission.completed = True
                break

    # Event hooks for progress tracking
    def on_combat_stage_cleared(self):
        """Called when a PvE combat stage is cleared."""
        self.update_progress("pve_clear_stages")
        self.update_progress("pve_no_death")  # Assuming no death for now

    def on_enemy_defeated(self):
        """Called when an enemy is defeated."""
        self.update_progress("pve_defeat_enemies")

    def on_weapon_skill_used(self):
        """Called when a weapon skill is used."""
        self.update_progress("pve_use_skills")

    def on_weapon_switched(self):
        """Called when weapon is switched in combat."""
        self.update_progress("weapon_switch")

    def on_weapon_ultimate_used(self):
        """Called when weapon ultimate is triggered."""
        self.update_progress("weapon_ultimate")

    def on_specific_weapon_used(self, weapon_name: str):
        """Called when completing mission with specific weapon."""
        # For simplicity, assume any weapon counts for now
        self.update_progress("weapon_specific")

    def on_vn_node_read(self):
        """Called when a VN node is read."""
        self.update_progress("vn_read_node")

    def on_vn_scene_replayed(self):
        """Called when a VN scene is replayed."""
        self.update_progress("vn_replay_scene")

    def on_pvp_match_played(self):
        """Called when a PvP match is played."""
        self.update_progress("pvp_play_match")

    def on_pvp_skill_used(self):
        """Called when a skill is used in PvP."""
        self.update_progress("pvp_use_skills")

    def on_fashion_equipped(self):
        """Called when fashion is equipped."""
        self.update_progress("fashion_equip")

    def claim_reward(self, mission_id: str) -> bool:
        """Claim reward for a completed mission."""
        for mission in self.missions:
            if mission.id == mission_id and mission.completed and not mission.claimed:
                if mission.reward.currency:
                    self.currency_manager.add(mission.reward.currency, mission.reward.amount)
                # Handle items if needed
                mission.claimed = True
                return True
        return False

    def claim_completion_bonus(self) -> bool:
        """Claim bonus for completing all missions."""
        if self.completion_bonus_claimed:
            return False
        all_completed = all(m.completed for m in self.missions if not m.optional)
        if all_completed:
            # Bonus reward: e.g., extra gems
            self.currency_manager.add("Gacha Gem", 100)
            self.completion_bonus_claimed = True
            return True
        return False

    def get_completion_status(self) -> Dict[str, Any]:
        """Get completion status for UI."""
        completed_count = sum(1 for m in self.missions if m.completed)
        total_required = sum(1 for m in self.missions if not m.optional)
        all_completed = completed_count >= total_required
        return {
            "missions": self.missions,
            "completed_count": completed_count,
            "total_count": len(self.missions),
            "all_completed": all_completed,
            "bonus_claimed": self.completion_bonus_claimed
        }

