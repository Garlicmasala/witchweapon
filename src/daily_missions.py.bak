                "claimed": m.claimed,
                "reward": {
                    "currency": m.reward.currency,
                    "amount": m.reward.amount,
                    "item": m.reward.item,
                    "item_amount": m.reward.item_amount
                }
                    "currency": m.reward.currency,
                    "amount": m.reward.amount,
                    "item": m.reward.item,
                    "item_amount": m.reward.item_amount
                },
                "optional": m.optional
            } for m in se]
        for m_data in data["missions"]:
            reward = MissionReward(**m_data["reward"])
            mission = DailyMission(
                id=m_data["id"],
                category=MissionCategory(m_data["category"]),
                title=m_data["title"],
                description=m_data["description"],
                target=m_data["target"],
                progress=m_data["progress"],
                completed=m_data["completed"],
                claimed=m_data["claimed"],
                reward=reward,
                optional=m_data["optional"]
            )
            self.missions.append(mission)
        }
        with open(self.save_file, 'w') as f:
            json.dump(data, f, indent=4)
        return data

    def load_state_from_dict(self, data: Dict[str, Any]):
        """Load daily mission state from dict."""
        from datetime import datetime
        self.last_reset_date = datetime.fromisoformat(data["last_reset_date"]) if data["last_reset_date"] else None
        self.completion_bonus_claimed = data["completion_bonus_claimed"]
        self.missions = [DailyMission(**m) for m in data["missions"]]
        self._check_daily_reset()  # Ensure up to date